# Pick ONE — the rest can stay commented. Or skip this file entirely and
# paste a key into the Settings panel after the dashboard boots.

# Groq — free, fast (recommended for EP05)
# GROQ_API_KEY=

# Gemini — free tier, https://aistudio.google.com/apikey
# GEMINI_API_KEY=

# Sarvam AI — best Tanglish quality, https://dashboard.sarvam.ai
# SARVAM_API_KEY=

# OpenAI / Anthropic — paid
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Local Ollama — set if you're running ollama on a non-default port
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# Dashboard wiring
# PORT=8000
# HOST=127.0.0.1
